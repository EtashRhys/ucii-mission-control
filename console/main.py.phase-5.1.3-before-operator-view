from pathlib import Path

import httpx

from fastapi import FastAPI, Request
from fastapi.responses import HTMLResponse
from fastapi.staticfiles import StaticFiles
from fastapi.templating import Jinja2Templates


BASE_DIR = Path(__file__).resolve().parent


MISSION_CONTROL_API = "http://127.0.0.1:8001"


app = FastAPI(
    title="UCII Mission Control Console",
    description="Private operator console for UCII Mission Control",
    version="0.3.0",
)


app.mount(
    "/static",
    StaticFiles(
        directory=BASE_DIR / "static"
    ),
    name="static",
)


templates = Jinja2Templates(
    directory=BASE_DIR / "templates"
)


def get_api_health():

    try:

        response = httpx.get(
            f"{MISSION_CONTROL_API}/health",
            timeout=3,
        )

        if response.status_code == 200:
            return "online"

    except Exception:
        pass


    return "offline"



def get_sessions():

    try:

        response = httpx.get(
            f"{MISSION_CONTROL_API}/sessions",
            timeout=5,
        )

        if response.status_code == 200:

            data = response.json()

            return data.get(
                "sessions",
                []
            )

    except Exception:
        pass


    return []



@app.get(
    "/",
    response_class=HTMLResponse,
)
def console_home(
    request: Request,
):

    sessions = get_sessions()


    return templates.TemplateResponse(
        request=request,
        name="base.html",
        context={

            "status": "online",

            "api_status":
                get_api_health(),

            "session_count":
                len(sessions),

            "sessions":
                sessions,

        },
    )



@app.get("/health")
def health():

    return {

        "service":
            "UCII Mission Control Console",

        "status":
            "healthy",

    }
