from pathlib import Path

import httpx

from fastapi import FastAPI, Request
from fastapi.responses import HTMLResponse
from fastapi.staticfiles import StaticFiles
from fastapi.templating import Jinja2Templates


BASE_DIR = Path(__file__).resolve().parent


MISSION_CONTROL_API = "http://127.0.0.1:8001"


app = FastAPI(
    title="UCII Mission Control Console",
    description="Private operator console for UCII Mission Control",
    version="0.4.0",
)


app.mount(
    "/static",
    StaticFiles(
        directory=BASE_DIR / "static"
    ),
    name="static",
)


templates = Jinja2Templates(
    directory=BASE_DIR / "templates"
)



def get_health():

    try:

        response = httpx.get(
            f"{MISSION_CONTROL_API}/health",
            timeout=3,
        )

        if response.status_code == 200:
            return "online"

    except Exception:
        pass

    return "offline"



def get_sessions():

    try:

        response = httpx.get(
            f"{MISSION_CONTROL_API}/sessions",
            timeout=5,
        )

        if response.status_code == 200:

            return response.json().get(
                "sessions",
                []
            )

    except Exception:
        pass


    return []



def summarize_sessions(sessions):

    summary = {

        "total": len(sessions),

        "high_activity": 0,

        "testing": 0,

        "documentation": 0,

        "healthy": 0,

        "attention": 0,

    }


    for session in sessions:


        if session.get(
            "activity_level"
        ) == "high":

            summary["high_activity"] += 1



        if session.get(
            "intent_signal"
        ) == "active_testing":

            summary["testing"] += 1



        if "documentation" in str(
            session.get("intent_signal")
        ):

            summary["documentation"] += 1



        if session.get(
            "session_health"
        ) == "healthy":

            summary["healthy"] += 1



        else:

            summary["attention"] += 1



    return summary



@app.get(
    "/",
    response_class=HTMLResponse,
)
def console_home(
    request: Request,
):


    sessions = get_sessions()


    return templates.TemplateResponse(

        request=request,

        name="base.html",

        context={

            "status":
                "online",

            "api_status":
                get_health(),

            "summary":
                summarize_sessions(
                    sessions
                ),

            "sessions":
                sessions,

        },

    )



@app.get("/health")
def health():

    return {

        "service":
            "UCII Mission Control Console",

        "status":
            "healthy",

    }
