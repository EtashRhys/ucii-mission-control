<!DOCTYPE html>
<html>

<head>

<title>
UCII Mission Control
</title>


<link
rel="stylesheet"
href="{{ url_for('static', path='style.css') }}"
>

</head>


<body>


<div class="container">


<h1>
UCII Mission Control
</h1>


<h2>
Private Operator Console
</h2>



<div class="panel">

<h3>
System Status
</h3>


<p>
Console:

<strong>
{{ status }}
</strong>

</p>


<p>
Mission Control API:

<strong>
{{ api_status }}
</strong>

</p>

</div>




<div class="panel">

<h3>
Operational Summary
</h3>


<p>
Active Sessions:

<strong>
{{ summary.total }}
</strong>
</p>


<p>
High Activity:

<strong>
{{ summary.high_activity }}
</strong>
</p>


<p>
Active Testing:

<strong>
{{ summary.testing }}
</strong>
</p>


<p>
Documentation Exploration:

<strong>
{{ summary.documentation }}
</strong>
</p>


<p>
Healthy:

<strong>
{{ summary.healthy }}
</strong>
</p>


<p>
Needs Attention:

<strong>
{{ summary.attention }}
</strong>
</p>


</div>





<div class="panel">


<h3>
Session Intelligence
</h3>


{% for session in sessions %}


<div class="session">


<h4>
Session
</h4>


<p>
Visitor:

<strong>
{{ session.visitor_id }}
</strong>
</p>


<p>
Current:

<strong>
{{ session.current_url }}
</strong>
</p>


<p>
Intent:

<strong>
{{ session.intent_signal }}
</strong>
</p>


<p>
Activity:

<strong>
{{ session.activity_level }}
</strong>
</p>


<p>
Pattern:

<strong>
{{ session.session_pattern }}
</strong>
</p>


<p>
Health:

<strong>
{{ session.session_health }}
</strong>
</p>


<p>
Reliability:

<strong>
{{ session.reliability_signal }}
</strong>
</p>


<p>
Last Event:

<strong>
{{ session.last_event_type }}
</strong>
</p>


</div>


{% endfor %}


</div>


</div>


</body>


</html>
